# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Database files — never commit the live DB, only the placeholder
Databases/*
!Databases/.gitkeep
Backups/*
!Backups/.gitkeep
*.db
*.db-shm
*.db-wal

# Streamlit secrets (keep config.toml but not secrets)
.streamlit/secrets.toml

# Environment & local overrides
.env
*.env

# Assets (logos etc.) — keep placeholder, ignore actual images
Assets/*
!Assets/.gitkeep

# OS
.DS_Store
Thumbs.db
